# App
NODE_ENV=development
PORT=4000
# Comma-separated allowlist of origins permitted by CORS.
CORS_ORIGIN=http://localhost:3000,http://localhost:5173,https://simpleinvoice.khangtran.dev

# Database - host is 'localhost' for local dev; overridden to 'postgres' in Docker
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=simple_invoice
POSTGRES_USER=simple_invoice_user
POSTGRES_PASSWORD=change-me-local-dev-password

# Auth - generate with: openssl rand -base64 32 (minimum 32 characters)
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars
JWT_EXPIRES_IN=3600

# Payments
APP_PUBLIC_URL=http://localhost:5173
PAYMENT_LINK_EXPIRES_IN_DAYS=30
EMAIL_PROVIDER=console
